# Database — Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# SMTP — for email notifications (e.g. Gmail, Resend, Mailgun)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Trackr <your@gmail.com>"

# Seed admin user (used by: npm run db:seed)
SEED_ADMIN_EMAIL="admin@yourcompany.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Admin"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# MCP Server — API key auth for Claude integration
# MCP_API_KEY: any strong random secret (generate: openssl rand -base64 32)
# MCP_API_USER_EMAIL: the Trackr account the MCP acts as
MCP_API_KEY="your-mcp-secret-here"
MCP_API_USER_EMAIL="Apoorwa@astura.ai"
